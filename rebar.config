{erl_opts, [debug_info]}.
{deps, [
    {nova, "0.12.1"},
    {jesse, "1.8.1"}
]}.

{dialyzer, [
    {plt_extra_apps, [
        nova,
        cowboy,
        ranch
    ]}
]}.

{project_plugins, [
    {erlfmt, "~>1.3"},
    rebar3_ex_doc
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"LICENSE", #{title => "License"}}
    ]},
    {main, "README.md"},
    {source_url, "https://github.com/novaframework/nova_json_schemas"}
]}.

{erlfmt, [
    write,
    {files, [
        "rebar.config",
        "src/*.app.src",
        "src/**/{*.erl, *.hrl}"
    ]}
]}.
